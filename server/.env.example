PORT=3001

# Origem permitida para o front-end (ajuste se hospedar em outro domínio/porta)
FRONTEND_ORIGIN=http://127.0.0.1:5500

# ID da agenda do Google que vai receber os agendamentos
# (em calendar.google.com > Configurações > Integrar agenda)
GOOGLE_CALENDAR_ID=xavierichard1506@gmail.com

# Credenciais OAuth (Google Cloud Console > Credenciais > Criar Credenciais > ID do cliente OAuth)
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:3001/oauth2callback

# Gerado automaticamente após visitar http://localhost:3001/autorizar
# (deixe vazio até completar a autorização)
GOOGLE_REFRESH_TOKEN=
